generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"    // 👈 必须把 sqlite 改成 mysql
  url      = env("DATABASE_URL")
}

// AI 工具表
model Tool {
  id            String    @id @default(cuid())
  name          String
  description   String
  url           String
  logo          String?
  categoryId    String
  subCategoryId String?
  tags          String    // 在 SQLite 中，数组可以用逗号分隔的字符串或 JSON 字符串存储
  views         Int       @default(0)
  isSponsored   Boolean   @default(false)
  sponsorExpiry DateTime?
  order         Int       @default(0) // 👈 新增：工具的自定义排序权重 (越高越排在前面)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 分类表
model Category {
  id        String   @id @default(cuid())
  name      String
  parentId  String?  
  icon      String?  
  order     Int      @default(0)
}

// 待审核的工具提交表（客户自助提交）
model PendingTool {
  id          String   @id @default(cuid())
  name        String
  description String
  url         String
  logo        String?  // 👈 新增：客户前台提交上来的 Logo 链接
  contactInfo String?  // 客户联系方式（微信/邮箱）
  status      String   @default("pending") // pending, approved, rejected
  createdAt   DateTime @default(now())
}

// 网站全局设置表
model SiteSetting {
  id              String  @id @default("default")
  name            String  @default("智能零零AI工具")
  logo            String? // 网站自定义Logo
  favicon         String? // 👈 新增：浏览器标签页小图标 (Favicon)
  titleFontSize   Int     @default(17) // 👈 新增：网站标题字体大小
  backgroundColor String  @default("#f5f5f7") // 👈 新增：网站全局背景色
  companyIntro    String? // 👈 新增：公司简介
  icp             String? // 👈 新增：备案号
  email           String? // 👈 新增：联系邮箱
}